{
  "info": {
    "_postman_id": "blog-api-collection",
    "name": "Blog API Collection",
    "description": "Complete API collection for Blog project with Users, Blogs, Comments, and Profiles",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Management",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securepassword123\",\n  \"role\": \"READER\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/user/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "user",
                "register"
              ]
            },
            "description": "Register a new user with name, email, password, and role (READER, AUTHOR, ADMIN)"
          },
          "response": []
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/user/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "user",
                "login"
              ]
            },
            "description": "Login with email and password to get access token"
          },
          "response": []
        },
        {
          "name": "Check Authentication",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/user/is_auth",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "user",
                "is_auth"
              ]
            },
            "description": "Check if user is authenticated using bearer token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Blogs",
      "item": [
        {
          "name": "Get All Blogs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/blogs/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "blogs",
                ""
              ]
            },
            "description": "Retrieve all blogs from the system"
          },
          "response": []
        },
        {
          "name": "Get Blog by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/blogs/{{blog_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "blogs",
                "{{blog_id}}"
              ]
            },
            "description": "Retrieve a specific blog by its ID"
          },
          "response": []
        },
        {
          "name": "Create Blog",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Getting Started with FastAPI\",\n  \"introduction\": \"FastAPI is a modern web framework for building APIs with Python 3.7+\",\n  \"content\": \"This blog post covers the basics of FastAPI, including routing, dependency injection, and request validation.\",\n  \"conclusion\": \"FastAPI provides an excellent balance of performance, developer experience, and code quality.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/blogs/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "blogs",
                ""
              ]
            },
            "description": "Create a new blog post (requires AUTHOR or ADMIN role)"
          },
          "response": []
        },
        {
          "name": "Update Blog",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"introduction\": \"Updated introduction text\",\n  \"content\": \"Updated content\",\n  \"conclusion\": \"Updated conclusion\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/blogs/{{blog_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "blogs",
                "{{blog_id}}"
              ]
            },
            "description": "Update an existing blog post (requires AUTHOR or ADMIN role)"
          },
          "response": []
        },
        {
          "name": "Delete Blog",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/blogs/blog/{{blog_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "blogs",
                "blog",
                "{{blog_id}}"
              ]
            },
            "description": "Delete a blog post (requires AUTHOR or ADMIN role)"
          },
          "response": []
        }
      ]
    },
